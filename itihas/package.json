{
  "name": "itihas",
  "version": "1.0.0",
  "description": "Bangladesh Heritage Explorer – Discover the rich cultural heritage of Bangladesh",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "seed": "node server/seed/seeder.js",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "keywords": [
    "bangladesh",
    "heritage",
    "culture",
    "mern",
    "explorer"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
